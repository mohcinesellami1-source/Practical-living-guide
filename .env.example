# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (secret — server only, NEVER exposed to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for canonical links, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=

# Monetisation / verification
ADSENSE_PUBLISHER_ID=
GOOGLE_SITE_VERIFICATION=
NEWSLETTER_FORM_URL=

# Affiliate networks (public tracking tags — safe in the browser bundle)
NEXT_PUBLIC_AMAZON_ASSOCIATE_TAG=
NEXT_PUBLIC_SHAREASALE_AFFILIATE_ID=

# Stripe — publishable key is browser-safe; SECRET key is SERVER-ONLY (never NEXT_PUBLIC_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Stripe webhook signing secret (only needed if you use webhooks)
STRIPE_WEBHOOK_SECRET=
